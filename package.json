{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Personal developer portfolio — static site bundled with esbuild.",
  "scripts": {
    "build": "esbuild src/App.jsx --bundle --format=esm --minify --define:process.env.NODE_ENV='\"production\"' --external:@data --outfile=src/app.bundle.js"
  },
